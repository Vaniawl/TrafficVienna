    "Try again from another location or open the map to explore the city.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Versuche es an einem anderen Ort erneut oder öffne die Karte, um die Stadt zu erkunden."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Спробуйте ще раз в іншому місці або відкрийте мапу, щоб переглянути місто."
          }
        }
      }
    },
    "Try another station name.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Versuche einen anderen Stationsnamen."
