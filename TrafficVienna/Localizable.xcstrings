            "value": "Anmelden"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Увійти"
          }
        }
      }
    },
    "Sign out": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Abmelden"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Вийти"
          }
        }
      }
    },
    "Source": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Quelle"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Джерело"
          }
        }
      }
    },
    "Star a station, or tap the heart on a line, to save it here.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Markiere eine Station mit dem Stern oder tippe auf das Herz einer Linie, um sie hier zu speichern."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Позначте станцію зірочкою або натисніть серце біля лінії, щоб зберегти її тут."
          }
        }
      }
    },
    "Start typing to see live departures anywhere in Vienna.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippe, um Live-Abfahrten in ganz Wien zu sehen."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Почніть вводити назву, щоб побачити актуальні відправлення по всьому Відню."
          }
        }
      }
    },
    "Station or stop": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Station oder Haltestelle"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Станція або зупинка"
          }
        }
      }
    },
    "Stations": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Stationen"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Станції"
          }
        }
      }
    },
    "The departures you care about": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Abfahrten, die dir wichtig sind"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Важливі для вас відправлення"
          }
        }
      }
    },
    "This deletes the local email password verifier and signs you out. Your saved stations and routines remain on this device.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch werden der lokale E-Mail-Passwortprüfwert gelöscht und du abgemeldet. Deine gespeicherten Stationen und Routinen bleiben auf diesem Gerät."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Це видалить локальний засіб перевірки пароля електронної пошти та виконає вихід. Збережені станції й сценарії залишаться на цьому пристрої."
          }
        }
      }
    },
    "This removes favourites, routines, recent searches, departure reminders, Live Activities, widget data, and cached departures. Your sign-in stays active.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch werden Favoriten, Routinen, letzte Suchanfragen, Abfahrtserinnerungen, Live-Aktivitäten, Widget-Daten und zwischengespeicherte Abfahrten gelöscht. Deine Anmeldung bleibt aktiv."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Це видалить обране, сценарії, недавні пошуки, нагадування про відправлення, Live Activities, дані віджета та кешовані відправлення. Вхід в акаунт залишиться активним."
          }
        }
      }
    },
    "This removes the Apple sign-in session from this device. It does not delete or revoke your Apple ID. Your saved stations and routines remain.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch wird die Apple-Anmeldesitzung von diesem Gerät entfernt. Deine Apple-ID wird weder gelöscht noch widerrufen. Deine gespeicherten Stationen und Routinen bleiben erhalten."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Це видалить сеанс входу Apple із цього пристрою. Ваш Apple ID не буде видалено чи відкликано. Збережені станції й сценарії залишаться."
          }
        }
      }
    },
    "Track on Lock Screen": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Am Sperrbildschirm verfolgen"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Відстежувати на екрані блокування"
          }
        }
      }
    },
    "Traffic Vienna": {
