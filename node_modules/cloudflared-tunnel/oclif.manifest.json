{
  "version": "1.0.3",
  "commands": {
    "cf-tunnel": {
      "id": "cf-tunnel",
      "description": "Start cloudflared tunnel to expose local server to the internet",
      "strict": true,
      "usage": " [-p <port>] [-h <host>] [-s]",
      "pluginName": "cloudflared-tunnel",
      "pluginAlias": "cloudflared-tunnel",
      "pluginType": "core",
      "aliases": [],
      "flags": {
        "port": {
          "name": "port",
          "type": "option",
          "char": "p",
          "description": "port to expose (default: 3000)",
          "multiple": false
        },
        "host": {
          "name": "host",
          "type": "option",
          "char": "h",
          "description": "host to expose (default: http://localhost)",
          "multiple": false
        },
        "setup": {
          "name": "setup",
          "type": "boolean",
          "char": "s",
          "description": "setup cloudflared tunnel (default: false)",
          "allowNo": false
        }
      },
      "args": {}
    },
    "setup": {
      "id": "setup",
      "strict": true,
      "pluginName": "cloudflared-tunnel",
      "pluginAlias": "cloudflared-tunnel",
      "pluginType": "core",
      "aliases": [],
      "flags": {},
      "args": {}
    }
  }
}